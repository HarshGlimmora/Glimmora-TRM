# ---------------------------------------------------------------------------
# Glimmora TRM — server-only environment template.
#
# 1. Copy this file to `.env.local` (which is git-ignored).
# 2. Replace every <PLACEHOLDER> with a real value.
# 3. Restart `npm run dev` for changes to take effect.
#
# Used by app/api/auth/send-otp and app/api/auth/verify-otp via
# lib/server/email.ts and lib/server/otp-store.ts.
# ---------------------------------------------------------------------------

# Which provider to try first: "smtp" or "resend". If the first fails, the
# other is attempted as a fallback. In dev, if both fail, the OTP is logged
# to the server console instead.
EMAIL_PROVIDER=smtp

# The "From" address shown on outgoing OTP emails.
EMAIL_FROM=<your-from-address@example.com>
EMAIL_FROM_NAME=Glimmora TRM

# --- SMTP (Gmail app password works here) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-smtp-user@example.com>
# For Gmail, generate an App Password at https://myaccount.google.com/apppasswords
# Spaces in the password are stripped automatically.
SMTP_PASS=<your-smtp-app-password>
SMTP_USE_TLS=true

# --- Resend (fallback if SMTP is unreachable) ---
# Get a key at https://resend.com/api-keys. Leave blank to disable.
RESEND_API_KEY=<your-resend-api-key>

# --- OTP behaviour ---
# OTP lifetime in seconds (default 600 = 10 minutes).
OTP_TTL_SECONDS=600
# Cooldown between OTP resends, in seconds.
OTP_RESEND_COOLDOWN_SECONDS=30
# Max wrong attempts before the OTP locks.
OTP_MAX_ATTEMPTS=5
# Lock duration after exhausting attempts, in seconds.
OTP_LOCK_SECONDS=60
