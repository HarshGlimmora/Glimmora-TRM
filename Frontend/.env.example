# ---------------------------------------------------------------------------
# Glimmora TRM — server-only environment template.
#
# 1. Copy this file to `.env.local` (which is git-ignored).
# 2. Replace every <PLACEHOLDER> with a real value.
# 3. Start the local Postgres (from the repo root):
#       docker compose up -d db
#    (or point DATABASE_URL at a Supabase project).
# 4. Restart `npm run dev`. Migrations apply on first request.
#
# Used by:
#   - app/api/auth/*           (OTP + session + me + logout + set-role)
#   - app/api/onboarding/*     (resume-from-step draft + final submit)
#   - app/api/ca-link          (consultant <-> taxpayer grant)
# ---------------------------------------------------------------------------

# --- Database --------------------------------------------------------------
# Leave DATABASE_URL UNSET for local dev — an embedded Postgres (PGlite)
# starts in-process at .data/pglite/ on first request, no setup required.
#
# Set DATABASE_URL to point at a real Postgres for prod / Supabase.
# Examples:
#   DATABASE_URL=postgres://glmra:glmra_dev@localhost:5432/glmra
#   DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.<ref>.supabase.co:5432/postgres

# --- Email (used to deliver OTPs) -------------------------------------------
# Provider to try first: "smtp" or "resend". If the first fails, the other
# is attempted as a fallback. In dev, if both fail, the OTP is logged to the
# server console instead.
EMAIL_PROVIDER=smtp

# The "From" address shown on outgoing OTP emails.
EMAIL_FROM=<your-from-address@example.com>
EMAIL_FROM_NAME=Glimmora TRM

# --- SMTP (Gmail app password works here) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-smtp-user@example.com>
# For Gmail, generate an App Password at https://myaccount.google.com/apppasswords
# Spaces in the password are stripped automatically.
SMTP_PASS=<your-smtp-app-password>
SMTP_USE_TLS=true

# --- Resend (fallback if SMTP is unreachable) ---
# Get a key at https://resend.com/api-keys. Leave blank to disable.
RESEND_API_KEY=<your-resend-api-key>

# --- OTP behaviour ---
OTP_TTL_SECONDS=600            # OTP lifetime (default 10 minutes)
OTP_RESEND_COOLDOWN_SECONDS=30 # Cooldown between resends
OTP_MAX_ATTEMPTS=5             # Wrong attempts before lock
OTP_LOCK_SECONDS=60            # Lock duration after exhausting attempts
