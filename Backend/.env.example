# Copy to .env and adjust as needed.

APP_NAME=GlimmoraTax
ENV=dev
DEBUG=true

# -------------------------------------------------------------------
# Database backend selection.
# Default is "sqlite" (local file). Set to "supabase" for cloud Postgres.
# We do NOT auto-fall-back between the two — change this explicitly.
# -------------------------------------------------------------------
DATABASE_BACKEND=sqlite

# --- SQLite settings (used when DATABASE_BACKEND=sqlite) ---
# Path is relative to the Backend/ directory.
# DB_PATH=data/app.db

# --- Supabase settings (used when DATABASE_BACKEND=supabase) ---
# Get the full URI from Supabase Dashboard -> Project Settings -> Database
# -> Connection string -> URI, then prefix with `postgresql+psycopg://`.
#
# Example:
# SUPABASE_DB_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@db.abcdefghijkl.supabase.co:5432/postgres
SUPABASE_DB_URL=

DB_ECHO=false

HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=["http://localhost:3000"]
